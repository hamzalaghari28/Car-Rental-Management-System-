# ============================================================
# Car Rental Management System — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values

# --- Backend API ---
PORT=3001
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# --- Frontend ---
VITE_API_URL=http://localhost:3001/api

# --- Jira Integration (optional — required for auto bug creation) ---
# Your Jira Cloud base URL (no trailing slash)
JIRA_BASE_URL=https://your-org.atlassian.net

# Your Atlassian account email
JIRA_EMAIL=your-email@example.com

# Jira API token — generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# Jira project key (e.g. CRM, CARS, DEV)
JIRA_PROJECT_KEY=CRM

# (Optional) Jira parent story key to link bugs to
JIRA_PARENT_STORY_KEY=CRM-1

# --- Test Configuration ---
BASE_URL=http://localhost:5173
